# NexaVault – Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ── Algorand Node ─────────────────────────────────────────────────────────────
ALGOD_URL=https://testnet-api.algonode.cloud
ALGOD_TOKEN=

# ── Smart Contract ────────────────────────────────────────────────────────────
# Set this after running: python scripts/deploy_contract.py
APP_ID=0

# ── Signing Account (TESTNET ONLY) ────────────────────────────────────────────
# Option A: 25-word mnemonic (recommended for testnet dev)
VAULT_MNEMONIC=word1 word2 word3 ... word25

# Option B: raw base64 private key (for CI/CD)
# VAULT_PRIVATE_KEY=

# ── Trading Parameters ────────────────────────────────────────────────────────
BUY_THRESHOLD_USD=0.15
SELL_THRESHOLD_USD=0.22
TRADE_AMOUNT_MICROALGO=1000000
SLIPPAGE=0.01

# ── AI Agent ──────────────────────────────────────────────────────────────────
AGENT_STRATEGY=rule
# MODEL_PATH=models/nexavault_agent.pkl

# ── Price Feed ────────────────────────────────────────────────────────────────
# Set to true to skip the CoinGecko API and use a mock price
USE_MOCK_PRICE=false

# ── Tinyman ───────────────────────────────────────────────────────────────────
TINYMAN_VALIDATOR_APP_ID=1002541853
USDC_ASSET_ID=10458941

# ── Server ────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO
